# Vite build-time env vars — required for both dev and build (enforced by vite.config.ts).
# For production: copy to .env.production and fill in prod values.

VITE_API_URL=
VITE_COGNITO_DOMAIN=
VITE_COGNITO_CLIENT_ID=

# VAPID public key for Web Push (generate with `npx web-push generate-vapid-keys`)
# The private key lives in AWS Secrets Manager; only the public key is needed here.
VITE_VAPID_PUBLIC_KEY=
