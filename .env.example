# Vite build-time env vars — copy to .env.production and fill in values before deploying.
# The build will fail if any of these are missing (enforced by vite.config.ts).

VITE_API_URL=
VITE_COGNITO_DOMAIN=
VITE_COGNITO_CLIENT_ID=

# VAPID public key for Web Push (generate with `npx web-push generate-vapid-keys`)
# The private key lives in AWS Secrets Manager; only the public key is needed here.
VITE_VAPID_PUBLIC_KEY=
